{
  "name": "vacancy-pilot",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@11.1.1",
  "scripts": {
    "dev": "wxt",
    "dev:firefox": "wxt -b firefox",
    "build": "wxt build",
    "build:firefox": "wxt build -b firefox",
    "zip": "wxt zip",
    "zip:firefox": "wxt zip -b firefox",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "test": "vitest run",
    "test:watch": "vitest",
    "verify": "pnpm typecheck && pnpm lint && pnpm test && pnpm build",
    "test:release": "pnpm build && vitest run --config vitest.release.config.ts src/release-safety"
  },
  "dependencies": {
    "dexie": "^4.4.4",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/chrome": "^0.1.43",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@wxt-dev/module-react": "1.2.2",
    "eslint": "^10.5.0",
    "happy-dom": "^20.10.6",
    "typescript": "^6.0.0",
    "typescript-eslint": "^8.61.1",
    "vitest": "^3.2.6",
    "wxt": "0.20.26"
  }
}
